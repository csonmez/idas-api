{
	"name": "idas-api",
	"version": "2.0.0",
	"description": "Institutional Data Analytics System API",
	"homepage": "https://github.com/csonmez/idas-api#readme",
	"bugs": {
		"url": "https://github.com/csonmez/idas-api/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/csonmez/idas-api.git"
	},
	"license": "ISC",
	"author": "Cem Sönmez <cem.sonmez@outlook.com.tr>",
	"type": "module",
	"main": "dist/server.js",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/server.ts",
		"build": "tsc",
		"start": "node dist/server.js",
		"start:local": "node --env-file=.env dist/server.js",
		"test": "tsx --test src/**/*.test.ts",
		"db:migrate": "kysely migrate:latest --config .config/kysely.config.ts",
		"db:rollback": "kysely migrate:down --config .config/kysely.config.ts",
		"db:rollback:all": "kysely migrate:rollback --all --config .config/kysely.config.ts",
		"db:make": "kysely migrate:make --config .config/kysely.config.ts",
		"db:codegen": "kysely-codegen --camel-case --singularize --out-file ./src/database/db.generated.ts",
		"db:seed:login-user": "tsx --env-file=.env src/scripts/seed-login-user.ts",
		"typecheck": "tsc --noEmit",
		"check": "biome check --write ."
	},
	"dependencies": {
		"bcryptjs": "^3.0.3",
		"connect-redis": "^9.0.0",
		"cors": "^2.8.6",
		"express": "^5.2.1",
		"express-rate-limit": "^8.5.2",
		"express-session": "^1.19.0",
		"helmet": "^8.2.0",
		"kysely": "^0.29.2",
		"passport": "^0.7.0",
		"pg": "^8.21.0",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"rate-limit-redis": "^5.0.0",
		"redis": "^6.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/express-session": "^1.19.0",
		"@types/node": "^25.9.1",
		"@types/passport": "^1.0.17",
		"@types/pg": "^8.20.0",
		"@types/supertest": "^7.2.0",
		"kysely-codegen": "^0.20.0",
		"kysely-ctl": "^0.21.0",
		"supertest": "^7.2.2",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3"
	}
}
